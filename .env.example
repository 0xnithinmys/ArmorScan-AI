# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=ArmorScan AI
DEBUG=false
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_A_LONG_RANDOM_STRING

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://armorscan:armorscan@localhost:5432/armorscan

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── AI Keys ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── ArmorIQ ───────────────────────────────────────────────────────────────────
ARMORIQ_API_KEY=your_armoriq_api_key_here
ARMORIQ_API_URL=https://api.armoriq.ai

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/ws
